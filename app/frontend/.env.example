# Frontend env variables (Vite)

# Base URL for Katet CRM API. Точка подключения backend (NestJS).
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Включает реальную auth и API-интеграцию.
# Если не установлено или != 'true' — app запускается в mock-режиме
# (без логина, все данные из /data/mock*.ts). Это режим Figma Make прототипа.
VITE_USE_API=false
