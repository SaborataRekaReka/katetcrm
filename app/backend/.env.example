# --- Runtime ---
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# --- Database ---
# Use docker-compose service hostname when running inside compose network.
# When running backend locally against dockerized Postgres, use localhost.
DATABASE_URL=postgresql://katet:katet@localhost:5433/katet_crm?schema=public

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173

# --- Integrations security ---
# HMAC-SHA256 signature over: <x-integration-timestamp>.<channel>.<stable-json-payload>
# Header names expected by API:
#   x-integration-timestamp: unix seconds or millis
#   x-integration-signature: sha256=<hex>
INTEGRATION_SITE_SECRET=
# Optional expected Mango PBX API key ("Уникальный код вашей АТС") for connector callbacks.
INTEGRATION_MANGO_API_KEY=
# Mango signing key ("Ключ для создания подписи"). Connector form callbacks are verified as:
#   sha256(vpbx_api_key + json + INTEGRATION_MANGO_SECRET)
INTEGRATION_MANGO_SECRET=
INTEGRATION_TELEGRAM_SECRET=
INTEGRATION_MAX_SECRET=
INTEGRATION_HMAC_TOLERANCE_SEC=300
# Set true to enforce webhook signatures in all environments (including local/CI).
INTEGRATION_REQUIRE_SIGNATURES=false
