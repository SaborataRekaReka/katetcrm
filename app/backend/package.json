{
  "name": "@katet/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Katet CRM backend (NestJS + Prisma + PostgreSQL)",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:backend": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "db:up": "docker compose -f docker-compose.yml up -d",
    "db:down": "docker compose -f docker-compose.yml down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "prepare:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-dev.ps1",
    "smoke:base": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke.ps1",
    "smoke:stages": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-stages.ps1",
    "smoke:stage3": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-stage3.ps1",
    "smoke:stage5": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-stage5.ps1",
    "smoke:stage6": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-stage6.ps1",
    "smoke:stage6:strict": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-stage6.ps1 -StrictProfile",
    "smoke:stage7": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-stage7.ps1",
    "smoke:tasks": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-tasks.ps1",
    "smoke:rbac": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-rbac.ps1",
    "smoke:rbac:scope": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-rbac-scope.ps1",
    "smoke:admin": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-admin.ps1",
    "smoke:admin:control": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-admin-control.ps1",
    "smoke:release": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-release.ps1",
    "smoke:flow": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-flow.ps1",
    "smoke:flow:repeat": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-flow-repeat.ps1 -Iterations 3",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
